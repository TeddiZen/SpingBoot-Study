<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace 对应你的 Mapper 接口全类名 -->
<mapper namespace="org.example.tliastest.mapper.EmpMapper">
    <select id="selectAll" resultType="org.example.tliastest.pojo.Emp">
        select e.*, d.name as deptName from emp e left join dept d on e.dept_id = d.id
        <where>
            <if test="name != null and name != ''">
                e.name like concat('%',#{name},'%')
            </if>
            <if test="gender != null">
                and e.gender = #{gender}
            </if>
            <if test="begin != null and end != null">
                and e.entry_date between #{begin} and #{end}
            </if>
        </where>
        order by e.entry_date desc
    </select>

    <select id="selectJobObjective">
        select
            (case job
                when 1 then '班主任'
                when 2 then '讲师'
                when 3 then '学工主管'
                when 4 then '教研主管'
                when 5 then '咨询师'
                else "其他" end)
            as jobName,
            count(*) as count
        from emp group by job order by count
    </select>
    <select id="selectEmpGenderData" resultType="java.util.Map">
        select
            (case gender
                when 1 then '男性员工'
                when 2 then '女性员工'
                end) as name,
            count(*) as value
        from emp group by gender
    </select>

    <!-- 登录查询 -->
    <select id="selectByUsernamePassword" resultType="org.example.tliastest.pojo.LoginObjective">
        select id, username, name from emp
        where username = #{username} and password = #{password}
    </select>

    <delete id="delEmp">
        delete from emp
        <where>
            id in <foreach collection="ids" item="id" open="(" close=")" separator=",">
                #{id}
            </foreach>
        </where>
    </delete>
    <!-- 上面的删除员工的原始语句是
         delete from emp where id in (1,2,3) -->

    <!-- 更新员工 -->
    <update id="updateEmp" parameterType="org.example.tliastest.pojo.Emp">
        update emp
        <set>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="gender != null">
                gender = #{gender},
            </if>
            <if test="phone != null and phone != ''">
                phone = #{phone},
            </if>
            <if test="job != null and job != ''">
                job = #{job},
            </if>
            <if test="salary != null">
                salary = #{salary},
            </if>
            <if test="image != null and image != ''">
                image = #{image},
            </if>
            <if test="entryDate != null">
                entry_date = #{entryDate},
            </if>
            <if test="deptId != null">
                dept_id = #{deptId},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime}
            </if>
        </set>
        where id = #{id}
    </update>

</mapper>